generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?

  senderEmails FromEmail[] 
  contacts     Contact[]   
  campaigns    Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model FromEmail {
  id        String   @id @default(uuid())
  email     String
  verified  Boolean  @default(false)

  userId String
  user   User @relation(fields: [userId], references: [id])

  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}


model Contact {
  id    String @id @default(uuid())
  email String
  name  String?

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model Campaign {
  id      String @id @default(uuid())
  subject String
  body    String

  status CampaignStatus @default(DRAFT)

  userId String
  user   User @relation(fields: [userId], references: [id])

  senderEmailId String
  senderEmail   FromEmail  @relation(fields: [senderEmailId], references: [id])

  recipients Recipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model Recipient {
  id String @id @default(uuid())

  email String

  status EmailStatus @default(PENDING)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 

  @@index([campaignId])
  @@index([email]) 
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING 
  SENT
}

enum EmailStatus {
  PENDING
  QUEUED     
  SENT
  DELIVERED
  OPENED
  BOUNCED
  FAILED
}